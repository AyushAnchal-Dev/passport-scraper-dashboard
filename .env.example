# ─────────────────────────────────────────────────────────────────────────────
# AERO-PASS Environment Variables
# Copy this file to .env and edit values as needed:  cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Docker Compose uses PostgreSQL (set automatically inside containers).
# For local host development without Docker, uncomment the SQLite line:
# DATABASE_URL=sqlite:///./dev_scraper.db
POSTGRES_DB=scraper_db
POSTGRES_USER=scraper_user
POSTGRES_PASSWORD=scraper_password

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Scraping ──────────────────────────────────────────────────────────────────
MOCK_SCRAPER_MODE=False
SCRAPE_INTERVAL_MINUTES=5

# ── CORS (Cross-Origin) ──────────────────────────────────────────────────────
# Set to "*" for local dev. For production set your frontend domain:
# CORS_ORIGINS=https://your-frontend.vercel.app,https://yourdomain.com
CORS_ORIGINS=*

# ── Translation ───────────────────────────────────────────────────────────────
SUPPORTED_LANGUAGES=en,hi,pa,es,fr,de,ar,zh,ru,ja

# ── Frontend (Next.js build-time variables) ───────────────────────────────────
# For local Docker:
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
# For production, set these to your deployed backend URL:
# NEXT_PUBLIC_API_URL=https://your-backend.onrender.com
# NEXT_PUBLIC_WS_URL=wss://your-backend.onrender.com

# ── Ports (optional, for Docker Compose) ──────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=3000
